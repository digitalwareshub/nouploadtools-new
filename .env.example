# Supabase — get from Supabase project dashboard → Settings → API
# These are public and safe to expose in browser bundles
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — PRIVATE, server-side only, never prefix with NEXT_PUBLIC_
# Used only by /admin server components. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin dashboard password — PRIVATE, server-side only, never prefix with NEXT_PUBLIC_
# Used to protect /admin. Choose a strong password.
ADMIN_PASSWORD=your-strong-admin-password-here

# Upstash Redis — PRIVATE, server-side only, never prefix with NEXT_PUBLIC_
# Used for rate limiting on /api/check-tracking. Get from console.upstash.com.
# If not set, rate limiting is skipped (fail-open).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# IndexNow — PRIVATE, server-side only, never prefix with NEXT_PUBLIC_
# Used to notify Bing/Yandex/others when new content is published.
# Generate a random key and host it at /{key}.txt in /public.
INDEXNOW_KEY=your-indexnow-key-here
